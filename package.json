{
  "name": "@demo-of-app-roi/root",
  "description": "Template for setting up a TypeScript monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "docs": "doctoc --title '**Table of content**' README.md",
    "clean": "pnpm run -r clean",
    "build": "pnpm run -r build",
    "build:apps": "pnpm run -r --parallel --filter './apps/*' build",
    "test": "pnpm run -r test --if-present",
    "lint": "eslint .",
    "dev": "pnpm run -r --parallel --filter './apps/*' dev",
    "dev:next": "pnpm --filter @demo-of-app-roi/nextjs dev",
    "dev:express": "pnpm --filter @demo-of-app-roi/express dev"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.0",
    "doctoc": "~2.3.0",
    "eslint": "~9.39.0",
    "eslint-plugin-prettier": "~5.5.0",
    "eslint-plugin-react": "~7.37.4",
    "globals": "~17.3.0",
    "prettier": "~3.8.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "~8.56.0"
  },
  "packageManager": "pnpm@10.30.2"
}
