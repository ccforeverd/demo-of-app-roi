NODE_ENV=development
PORT=3001
# 允许跨域的前端地址，多个地址用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000
# 单次查询最大返回行数
QUERY_LIMIT=50000
# MySQL Docker 容器 root 密码（仅 docker-compose 使用）
MYSQL_ROOT_PASSWORD=<your_root_password>
# MySQL 连接信息
DB_HOST=localhost
DB_PORT=3306
DB_USER=<your_db_user>
DB_PASSWORD=<your_db_password>
DB_NAME=app_roi
